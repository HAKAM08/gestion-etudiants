<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.monapp.controller.AnneeAddController"
      spacing="30"
      alignment="TOP_CENTER"
      style="
          -fx-padding:40;
          -fx-background-color:linear-gradient(to bottom, #f5f7fa, #e9ecf1);
      ">

    <!-- Card -->
    <VBox spacing="25"
          alignment="TOP_LEFT"
          maxWidth="480"
          style="
              -fx-padding:35;
              -fx-background-color:white;
              -fx-background-radius:14;
              -fx-border-radius:14;
              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 18, 0, 0, 6);
          ">

        <!-- Title -->
        <Label text="✨ Ajouter une Année"
               style="
                   -fx-font-size:24;
                   -fx-font-weight:bold;
                   -fx-text-fill:#2c3e50;
               "/>

        <Label text="Créez une nouvelle année académique pour organiser vos données"
               wrapText="true"
               style="
                   -fx-font-size:14;
                   -fx-text-fill:#6b7280;
               "/>

        <!-- Form -->
        <VBox spacing="10">
            <Label text="Nom de l'année"
                   style="
                       -fx-font-size:14;
                       -fx-font-weight:600;
                       -fx-text-fill:#374151;
                   "/>

            <TextField fx:id="nomField"
                       promptText="Ex: 2024 - 2025"
                       style="
                           -fx-font-size:16;
                           -fx-padding:12 14 12 14;
                           -fx-background-radius:8;
                           -fx-border-radius:8;
                           -fx-border-color:#cbd5e1;
                       "/>
        </VBox>

        <!-- Buttons -->
        <HBox spacing="14" alignment="CENTER_RIGHT">

            <Button text="Retour"
                    onAction="#onBack"
                    style="
                        -fx-background-color:#e5e7eb;
                        -fx-text-fill:#374151;
                        -fx-font-size:14;
                        -fx-padding:10 22 10 22;
                        -fx-background-radius:8;
                    "/>

            <Button text="➕ Enregistrer"
                    onAction="#onSave"
                    style="
                        -fx-background-color:#22c55e;
                        -fx-text-fill:white;
                        -fx-font-size:15;
                        -fx-font-weight:bold;
                        -fx-padding:12 26 12 26;
                        -fx-background-radius:8;
                    "/>

        </HBox>

    </VBox>

</VBox>
