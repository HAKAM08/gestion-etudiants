<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="465.0" prefWidth="321.0" style="-fx-background-color: linear-gradient(to bottom right, #34495e, #2c3e50);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.monapp.controller.LoginController">

    <center>
        <VBox alignment="CENTER" maxWidth="320" spacing="18" style="                 -fx-background-color: white;                 -fx-padding: 35;                 -fx-background-radius: 8;                 -fx-border-radius: 8;                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 15, 0, 0, 5);               ">


            <Label style="                         -fx-font-size: 22;                         -fx-font-weight: bold;                         -fx-text-fill: #2c3e50;                    " text="Administration" />


            <VBox alignment="CENTER_LEFT" spacing="6">
                <Label style="-fx-text-fill: #2c3e50;" text="Nom d'utilisateur" />
                <TextField fx:id="usernameField" prefWidth="260" promptText="admin" style="                                 -fx-background-radius: 4;                                 -fx-border-radius: 4;                                 -fx-border-color: #dcdcdc;                                 -fx-padding: 8;                            " />
            </VBox>


            <VBox alignment="CENTER_LEFT" spacing="6">
                <Label style="-fx-text-fill: #2c3e50;" text="Mot de passe" />
                <PasswordField fx:id="passwordField" prefWidth="260" promptText="••••••••" style="                                     -fx-background-radius: 4;                                     -fx-border-radius: 4;                                     -fx-border-color: #dcdcdc;                                     -fx-padding: 8;                                " />
            </VBox>


            <Button onAction="#onLogin" prefHeight="36.0" prefWidth="250.0" style="                         -fx-background-color: #2980b9;                         -fx-text-fill: white;                         -fx-font-size: 14;                         -fx-font-weight: bold;                         -fx-background-radius: 4;                         -fx-cursor: hand;                     " text="Se connecter" />


            <Label fx:id="messageLabel" alignment="CENTER" prefWidth="260" style="-fx-text-fill: #c0392b;" wrapText="true" />

        </VBox>
    </center>

</BorderPane>
