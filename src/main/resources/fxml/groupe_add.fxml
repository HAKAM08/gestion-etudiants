<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.monapp.controller.GroupeAddController"
      spacing="30"
      alignment="TOP_CENTER"
      style="
          -fx-padding:40;
          -fx-background-color:linear-gradient(to bottom, #f5f7fa, #e9ecf1);
      ">

    <!-- ================= CARD ================= -->
    <VBox spacing="25"
          alignment="TOP_LEFT"
          maxWidth="500"
          style="
              -fx-padding:35;
              -fx-background-color:white;
              -fx-background-radius:14;
              -fx-border-radius:14;
              -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.18), 18, 0, 0, 6);
          ">

        <!-- ================= TITLE ================= -->
        <Label text="➕ Ajouter un Groupe"
               style="
                   -fx-font-size:24;
                   -fx-font-weight:bold;
                   -fx-text-fill:#2c3e50;
               "/>

        <Label text="Créez un nouveau groupe et associez-le à une année académique"
               wrapText="true"
               style="
                   -fx-font-size:14;
                   -fx-text-fill:#6b7280;
               "/>

        <!-- ================= FORM ================= -->
        <VBox spacing="12">

            <Label text="Nom du groupe"
                   style="
                       -fx-font-size:14;
                       -fx-font-weight:600;
                       -fx-text-fill:#374151;
                   "/>

            <TextField fx:id="nomField"
                       promptText="Ex: Groupe A"
                       style="
                           -fx-font-size:16;
                           -fx-padding:12 14;
                           -fx-background-radius:8;
                           -fx-border-radius:8;
                           -fx-border-color:#cbd5e1;
                       "/>

            <Label text="Année académique"
                   style="
                       -fx-font-size:14;
                       -fx-font-weight:600;
                       -fx-text-fill:#374151;
                   "/>

            <ComboBox fx:id="anneeBox"
                      promptText="Sélectionner une année"
                      prefHeight="42"
                      style="
                          -fx-font-size:15;
                          -fx-background-radius:8;
                          -fx-border-radius:8;
                          -fx-border-color:#cbd5e1;
                      "/>

        </VBox>

        <!-- ================= ACTIONS ================= -->
        <HBox spacing="14" alignment="CENTER_RIGHT">

            <Button text="Retour"
                    onAction="#onBack"
                    style="
                        -fx-background-color:#e5e7eb;
                        -fx-text-fill:#374151;
                        -fx-font-size:14;
                        -fx-padding:10 22;
                        -fx-background-radius:8;
                    "/>

            <Button text="💾 Enregistrer"
                    onAction="#onSave"
                    style="
                        -fx-background-color:#22c55e;
                        -fx-text-fill:white;
                        -fx-font-size:15;
                        -fx-font-weight:bold;
                        -fx-padding:12 26;
                        -fx-background-radius:8;
                    "/>

        </HBox>

    </VBox>

</VBox>
